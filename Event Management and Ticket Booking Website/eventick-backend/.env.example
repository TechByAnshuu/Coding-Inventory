NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://eventick_admin:<db_password>@eventick-cluster.1hbbi8n.mongodb.net/eventickDB?retryWrites=true&w=majority&appName=eventick-cluster

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# Razorpay (Test Mode)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-admin.json

# Email Service (Gmail SMTP)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Eventick <noreply@eventick.com>

# SendGrid (Optional - uncomment if using SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key

# Redis (Optional - for OTP storage, falls back to in-memory)
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# WebSocket
WEBSOCKET_ENABLED=true
SEAT_LOCK_DURATION=300000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=3
AUTH_RATE_LIMIT_MAX=5

# Cloudinary (Optional)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
